# ==============================================================================
# COMPREHENSIVE GITIGNORE FOR PHANTOMTRACE PROJECT
# ==============================================================================
# This file prevents accidental commits of sensitive data, dependencies, and 
# build artifacts. Review before initial commit to GitHub.
# ==============================================================================

# ==============================================================================
# SECURITY: Never commit secrets, credentials, API keys, or local configs
# ==============================================================================

# Environment files with credentials (local development)
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# API keys and secrets
*.key
*.pem
*.p8
*.pfx
*.pkcs12
secrets/
private/
credentials.json
config/credentials.*

# Local config overrides (machine-specific settings)
local.config.js
local.settings.json

# ==============================================================================
# BACKEND: Python, virtual environments, caches
# ==============================================================================

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
dist/
build/

# Python testing and coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
*.cover
*,cover
.hypothesis/

# Linters and type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pylint

# Virtual environments (CRITICAL: repo should use requirements.txt instead)
venv/
.venv/
env/
ENV/
./venv/
node_venv/
.env_backup/

# Python development
pip-log.txt
pip-delete-this-directory.txt
.pyenv

# Database files (SQLite development artifacts)
*.sqlite3
*.db
*.sqlite
backend/agent_results_cache.sqlite3
backend/agent_results_cache*.db
backend/*.sqlite3
backend/*.db

