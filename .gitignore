# ==============================================================================
# PROTECTED PATTERNS: NEVER COMMIT THESE
# ==============================================================================

# Explicitly protect credential-like patterns even if they slip through above
*.secret
*.password
*.token
*_secret*
*_password*
*_token*
*_key*
*credentials*
*auth.json
*config.prod.js

# MongoDB connection strings
mongo_credentials.txt
mongodb_uri.txt

# AWS/Cloud credentials
aws_credentials
.aws/credentials
.aws/config
gcp_credentials.json
azure_secrets.json

# ==============================================================================
# EXCEPTIONS: Files that SHOULD be committed (prefixed with !)
# ==============================================================================

# Important template files
!.env.example
!.env.local.example
!.env.development.example

# Documentation and config templates
!.gitkeep
!README.md
!LICENSE

# ==============================================================================
# PROJECT-SPECIFIC INCLUSIONS (if needed, uncomment)
# ==============================================================================

# Keep certain build outputs or vendor libraries if required:
# !vendor/
# !public/uploads/
# !static/

# ==============================================================================
# BEFORE PUSHING TO GITHUB
# ==============================================================================
# 1. Run: git status (verify only intended files appear)
# 2. Run: git log --name-status HEAD~5..HEAD (check recent commits)
# 3. Scan: grep -r "GOOGLE_API_KEY\|VIRUSTOTAL_API_KEY\|password\|secret" --include="*.py" --include="*.js"
# 4. If secrets found in history: use git-filter-branch or BFG Repo-Cleaner
# 5. Verify no .env, .env.local, or config files with keys are staged
# ==============================================================================
